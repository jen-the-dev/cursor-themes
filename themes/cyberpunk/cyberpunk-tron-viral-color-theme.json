{
  "name": "Cyberpunk - TRON Viral",
  "type": "dark",
  "colors": {
    "editor.background": "#220011",
    "editor.foreground": "#ff4488",
    "editor.lineHighlightBackground": "#ffffff0a",
    "editorLineNumber.foreground": "#444444",
    "editorLineNumber.activeForeground": "#ff0088",
    "editorGutter.background": "#220011",
    "sideBar.background": "#ffffff08",
    "foreground": "#ff4488",
    "descriptionForeground": "#666666",
    "list.highlightForeground": "#ff0088",
    "dropdown.background": "#ffffff10",
    "list.hoverBackground": "#ffffff18",
    "panel.border": "#333333",
    "focusBorder": "#ff0088",
    "editorGroupHeader.tabsBackground": "#220011",
    "tab.activeBackground": "#ffffff08",
    "tab.inactiveBackground": "#220011",
    "panel.background": "#ffffff05",
    "titleBar.activeBackground": "#220011",
    "statusBar.background": "#220011",
    "terminal.background": "#220011",
    "terminal.foreground": "#ff4488",
    "terminal.ansiBlack": "#220011",
    "terminal.ansiRed": "#ff5555",
    "terminal.ansiGreen": "#ff0088",
    "terminal.ansiYellow": "#ffff55",
    "terminal.ansiBlue": "#5555ff",
    "terminal.ansiMagenta": "#ff4488",
    "terminal.ansiCyan": "#ff0088",
    "terminal.ansiWhite": "#ff4488",
    "activityBar.background": "#ffffff08",
    "sideBarTitle.foreground": "#ff4488",
    "editorCursor.foreground": "#ff4488",
    "selection.background": "#264f78"
  },
  "tokenColors": [
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff0088",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#88cc88"
      }
    },
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#666666",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#ff4488"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#ff0088"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#ff0088"
      }
    },
    {
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#ff0088"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#ff4488"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#ff4488"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ff4488"
      }
    },
    {
      "scope": [
        "constant",
        "constant.language"
      ],
      "settings": {
        "foreground": "#ff0088",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#ff0088"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ff4488"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.class"
      ],
      "settings": {
        "foreground": "#ff0088"
      }
    },
    {
      "scope": [
        "string.other.embedded",
        "meta.embedded"
      ],
      "settings": {
        "foreground": "#ff4488"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#ff0088",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.italic",
        "emphasis"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.bold",
        "strong"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    }
  ]
}
